# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).

# --- Database ---
DB_URL=jdbc:mysql://localhost:3307/seal_db
DB_USERNAME=root
DB_PASSWORD=

# --- JWT (shared) --- generate: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRATION=86400000        # access token, 1 day (ms)
JWT_REFRESH_EXPIRATION=604800000  # refresh token, 7 days (ms)

# --- Swagger ---
SWAGGER_ENABLED=true

# --- Mail (FR-AWD-02 result notifications) ---
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=

# --- General ---
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
